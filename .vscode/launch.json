{
    // Use IntelliSense to learn about possible attributes.
    // Hover to view descriptions of existing attributes.
    // For more information, visit: https://go.microsoft.com/fwlink/?linkid=830387
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Python Debugger: Current File",
            "type": "debugpy",
            "request": "launch",
            "program": "${file}",
            "console": "integratedTerminal",
            "justMyCode": false
        },
        {
            "name": "Debug Gradio App (Current File)",
            "type": "debugpy",
            "request": "launch",
            "program": "${file}",
            "console": "integratedTerminal",
            "justMyCode": false,
            "gevent": true
        },
        {
            "name": "CrewAI: stock picker",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/3_crew/stock_picker/src/stock_picker/main.py",
            "cwd": "${workspaceFolder}/3_crew/stock_picker",
            "python": "${workspaceFolder}/3_crew/stock_picker/.venv/bin/python",
            "env": {
                "PYTHONPATH": "${workspaceFolder}/3_crew/stock_picker/src"
            },
            "console": "integratedTerminal",
            "justMyCode": false
        },
        {
            "name": "Debug Sidekick App",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/4_langgraph/app.py",
            "cwd": "${workspaceFolder}/4_langgraph",
            "console": "integratedTerminal",
            "justMyCode": false
        },
        {
            "name": "Debug AutoGen Creator",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/5_autogen/world.py",
            "cwd": "${workspaceFolder}/5_autogen",
            "console": "integratedTerminal",
            "justMyCode": false
        }
    ]
}